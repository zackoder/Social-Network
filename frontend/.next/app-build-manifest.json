{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/page.css",
      "static/chunks/app/page.js"
    ],
    "/(dynamic)/profile/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(dynamic)/profile/page.css",
      "static/chunks/app/(dynamic)/profile/page.js"
    ],
    "/(static)/sign-up/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(static)/sign-up/page.css",
      "static/chunks/app/(static)/sign-up/page.js"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/_not-found/page.js"
    ]
  }
}